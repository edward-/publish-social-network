# Social Media Publisher - Environment Configuration Template
# Copy this file to .env and fill in your credentials

# =============================================================================
# MULTI-ACCOUNT SUPPORT
# =============================================================================
# You can configure multiple accounts per platform using profiles.
# Use the --profile flag to select which account to use:
#   ./publisher publish --profile work --platforms facebook
#
# Profile naming convention:
#   - Base keys (no suffix): Default account
#   - Suffix with "_PROFILE": Named account (e.g., FACEBOOK_PAGE_ID_WORK)
#
# Example with multiple accounts:
#   FACEBOOK_PAGE_ID=default_id
#   FACEBOOK_ACCESS_TOKEN=default_token
#   FACEBOOK_PAGE_ID_WORK=work_id
#   FACEBOOK_ACCESS_TOKEN_WORK=work_token
#   FACEBOOK_PAGE_ID_PERSONAL=personal_id
#   FACEBOOK_ACCESS_TOKEN_PERSONAL=personal_token

# =============================================================================
# FACEBOOK
# =============================================================================
# Your Facebook Page ID (found in Page Settings > About > Page ID)
FACEBOOK_PAGE_ID=your_page_id

# Long-lived Page Access Token from Facebook Developer Console
# Token must have: pages_manage_posts, pages_read_engagement permissions
# Note: Tokens expire and need to be renewed periodically
FACEBOOK_ACCESS_TOKEN=your_long_lived_token

# =============================================================================
# INSTAGRAM
# =============================================================================
# Your Instagram User ID (found via Facebook Developer Console or Graph API)
INSTAGRAM_USER_ID=your_ig_user_id

# Instagram Graph API Access Token (obtained via Facebook OAuth)
# Must have: instagram_basic, instagram_content_publish, pages_read_engagement
INSTAGRAM_ACCESS_TOKEN=your_ig_token

# =============================================================================
# TIKTOK
# =============================================================================
# TikTok OAuth 2.0 Access Token
# Required scopes: video.upload, video.publish
# Note: TikTok tokens require browser-based user consent flow to obtain
# See README for manual token exchange instructions
TIKTOK_ACCESS_TOKEN=your_tiktok_token

# TikTok Application Client Key (from TikTok Developer Portal)
TIKTOK_CLIENT_KEY=your_client_key

# =============================================================================
# YOUTUBE
# =============================================================================
# YouTube OAuth2 Client ID (from Google Cloud Console)
YOUTUBE_CLIENT_ID=your_client_id

# YouTube OAuth2 Client Secret (from Google Cloud Console)
YOUTUBE_CLIENT_SECRET=your_client_secret

# YouTube OAuth2 Refresh Token
# This is a long-lived token that refreshes the access token automatically
# Obtain via: OAuth2 flow with youtube.force_ssl_scope
YOUTUBE_REFRESH_TOKEN=your_refresh_token
